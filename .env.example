# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: restrict Flux to only respond to specific phone numbers (comma-separated)
# Leave blank to respond to all incoming DMs
ALLOWED_SENDERS=

# Optional: override the SQLite database path (default: ./flux.db)
FLUX_DB_PATH=./flux.db

# Optional: Claude model to use (default: claude-sonnet-4-5)
# Other options: claude-opus-4-6 (slower, smarter), claude-haiku-4-5 (faster, cheaper)
CLAUDE_MODEL=claude-sonnet-4-5
